---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MediaGrid from "../../components/MediaGrid.astro";
import PodcastGrid from "../../components/PodcastGrid.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { getTaxonomyIndex, getTaxonomyPage } from "../../lib/content-domain";
export async function getStaticPaths() {
  const taxonomy = await getTaxonomyIndex("speakers");

  return Promise.all(
    taxonomy.items.map(async (item) => ({
      params: { slug: item.slug },
      props: { page: await getTaxonomyPage("speakers", item.slug) },
    })),
  );
}

const { page } = Astro.props;
const { posts, item: speakerItem, podcastPosts, videoPosts } = page;
const videoCount = videoPosts.length;
const podcastCount = podcastPosts.length;
const totalCount = posts.length;

---

<BaseLayout sidebar={false} metadataProps={{ title: speakerItem.name }}>
  <div class="taxonomy-header">
    <h1 class="taxonomy-header__title">{speakerItem.name}</h1>
    <div class="taxonomy-header__links">
    <span class="taxonomy-header__count">{totalCount} items</span>
     {videoPosts && videoPosts.length > 0 && <a href="#video">{videoCount} videos</a>}
     {podcastPosts && podcastPosts.length > 0 &&
    <a href="#podcast">{podcastCount} podcasts</a>}
    </div>
  </div>
  <div class="container">
    {videoPosts && videoPosts.length > 0 && (
      <>
        <a name="video"></a>
        <SectionHeader
          title={`${videoCount} videos`}
          padding={true}
          anchor="video"
        />
        <MediaGrid media={videoPosts} layoutType="list" />
      </>
    )}
  </div>
  {podcastPosts && podcastPosts.length > 0 && (
    <>
      <a name="podcast"></a>
      <SectionHeader
        title={`${podcastCount} podcasts`}
        padding={true}
        anchor="podcast"
      />
      <PodcastGrid media={podcastPosts} />
    </>
  )}
</BaseLayout>

<style>
  .container {
    margin-bottom: 2rem;
  }
</style>
