---
import PodcastGrid from "../../components/PodcastGrid.astro";
import ShowGrid from "../../components/ShowGrid.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getRecentPodcasts, getRecentShows } from "../../lib/content-domain";

const [podcast, shows] = await Promise.all([
  getRecentPodcasts(8),
  getRecentShows(6),
]);
---

<BaseLayout sidebar={false} metadataProps={{ title: "All podcasts" }}>
  <div class="show"><SectionHeader
    title="Podcasts"
    link="/show/"
    linkLabel="All podcasts"
    padding={true}
  />
  <ShowGrid media={shows} /></div>
  <SectionHeader
    title="Latest podcast episodes"
    padding={true}
  />
  <PodcastGrid media={podcast} eagerLoadCount={6} />
</BaseLayout>
<style>
  .show {
    margin-bottom: 2rem;
  }
</style>
