---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShowLayout from "../../layouts/ShowLayout.astro";
import { getPodcastEntries } from "../../lib/content-domain";

export async function getStaticPaths() {
  const podcasts = await getPodcastEntries();
  return podcasts.map((podcast) => ({
    params: { slug: podcast.slug },
    props: podcast,
  }));
}

const post = Astro.props;

const { Content } = await post.render();
const headProps = {
  title: `${post.data.title} | Podcast`,
  description: post.data.description || post.data.title,
  image: post.data.image?.src,
};
---
<BaseLayout sidebar={false} fullWidth={true} metadataProps={headProps}>
<ShowLayout 
  {...post.data}
  slug={post.slug}
>
  <Content />
</ShowLayout>
</BaseLayout>
