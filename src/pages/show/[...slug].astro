---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShowLayout from "../../layouts/ShowLayout.astro";
import { getShowEntries, getShowPage } from "../../lib/content-domain";

export async function getStaticPaths() {
  const shows = await getShowEntries();
  return Promise.all(shows.map(async (show) => ({
    params: { slug: show.slug },
    props: { page: await getShowPage(show.slug) },
  })));
}

const { page } = Astro.props;
const show = page?.show;
const episodes = page?.episodes ?? [];

if (!show) {
  throw new Error(`Show page data missing for slug "${Astro.params.slug}"`);
}

const { Content } = await show.render();
const headProps = {
  title: `${show.data.title} | Podcast`,
  description: show.data.description || show.data.title,
  image: show.data.image?.src,
};
---
<BaseLayout sidebar={false} fullWidth={true} metadataProps={headProps} >
<ShowLayout 
  {...show.data}
  slug={show.slug}
  episodes={episodes}
>
  <Content />
</ShowLayout>
</BaseLayout>
