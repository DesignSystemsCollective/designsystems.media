---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MediaGrid from "../../components/MediaGrid.astro";
import PodcastGrid from "../../components/PodcastGrid.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { getTaxonomyIndex, getTaxonomyPage } from "../../lib/content-domain";

export async function getStaticPaths() {
  const taxonomy = await getTaxonomyIndex("tags");

  return Promise.all(
    taxonomy.items.map(async (item) => ({
      params: { slug: item.slug },
      props: { page: await getTaxonomyPage("tags", item.slug) },
    })),
  );
}

const { page } = Astro.props;
const { posts, item, podcastPosts, videoPosts } = page;
const videoCount = videoPosts.length;
const podcastCount = podcastPosts.length;
const totalCount = posts.length;
---

<BaseLayout sidebar={false} metadataProps={{ title: item.name }}>
  <h1>{item.name}</h1>
  <div class="header-links">
    <span class="total">{totalCount} items</span>
     {videoPosts && videoPosts.length > 0 && <a href="#video">{videoCount} videos</a>}
     {podcastPosts && podcastPosts.length > 0 &&
    <a href="#podcast">{podcastCount} podcasts</a>}
  </div>
  {videoPosts && videoPosts.length > 0 && (
    <>
      <SectionHeader
        title={`${videoCount} videos`}
        padding={true}
        anchor="video"
      />
      <MediaGrid media={videoPosts} layoutType="list" />
    </>
  )}
  {podcastPosts && podcastPosts.length > 0 && (
    <>
      <SectionHeader
        title={`${podcastCount} podcasts`}
        padding={true}
        anchor="podcast"
      />
      <PodcastGrid media={podcastPosts} />
    </>
  )}
</BaseLayout>

<style>
  h1 {
    margin: 0rem 1rem 0;
  }
  h2 {
    margin-block: 0 2rem;
  }
  .container {
    margin-bottom: 2rem;
  }
  .header-links {
    margin: 0rem 1rem 2rem;
    display: flex;
    gap: 1em;
    font-size: 0.9em;
    font-weight: 600;
    color: var(--tx-3)
  }
  .header-links a {
    text-decoration: none;
  }


  @media (max-width: 1024px) {
  h1 {
    margin: 1rem 1rem 0;
  }
    h2,
    .breadcrumb {
      padding-left: 1rem;
      margin: 0;
    }
  }
</style>
