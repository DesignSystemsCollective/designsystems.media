---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { getShowImage } from "../utils/images";
import FormattedDate from "../components/FormattedDate.astro";
import { IMAGE_WIDTHS, IMAGE_SIZES } from "../utils/imageSizes";

type Media = CollectionEntry<"show">;
type Props = Media["data"] & { 
  slug?: Media["slug"];
  loading?: "lazy" | "eager";
  latestEpisodeDate?: Date | null;
};

const { title, image, slug, speakers, episodeCount, lastUpdate, latestEpisodeDate, loading = "lazy" } = Astro.props;
const lastUpdateDate = latestEpisodeDate ?? new Date(lastUpdate);
const posterImage = getShowImage(slug, false);

---

<div class="media-card media-card--hover">
  <a href={`/show/${slug}/`} class="media-card__link">
    <div class="media-card__image media-card__image--square shadow">
      {posterImage ? (
        <Image 
          src={posterImage}
          alt={title}
          widths={[...IMAGE_WIDTHS.extraLarge]}
          sizes={IMAGE_SIZES.card}
          loading={loading}
          decoding="async"
        />
      ) : image ? (
        // image is ImageMetadata from content collection, use it directly
        <Image 
          src={image}
          alt={title}
          widths={[...IMAGE_WIDTHS.extraLarge]}
          sizes={IMAGE_SIZES.card}
          loading={loading}
          decoding="async"
        />
      ) : null}
    </div>
    <div class="media-card__content">
      <h3 class="media-card__title show-card__title">{title}</h3>
      <div class="media-card__meta show-card__speakers">{speakers.join(", ")}</div>
      <div class="media-card__meta show-card__meta">
        <span><FormattedDate date={lastUpdateDate} /></span> 
        <span>•</span> <span>{episodeCount} episodes</span>
      </div>
    </div>
  </a>
</div>

<style>
  .show-card__title {
    font-size: 16px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
  }

  .show-card__speakers {
    font-size: 15px;
  }

  .show-card__meta {
    font-size: 13px;
    color: var(--tx-3);
  }
</style>
