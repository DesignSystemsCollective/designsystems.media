---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import { formatDuration } from "../utils/formatDuration";
import { getShowImage } from "../utils/images";
import MediaImage from "./media/MediaImage.astro";

type Media = CollectionEntry<"podcast">;
type Props = Media["data"] & {
  slug?: Media["slug"];
  layoutType?: "grid" | "list";
  loading?: "lazy" | "eager";
};

const {
  title,
  publishedAt,
  duration = "",
  image,
  slug,
  hasEpisodeImage,
  showSlug,
  podcastTitle,
  layoutType = "grid",
  loading = "lazy",
} = Astro.props;

// If episode has its own image, use it; otherwise, use show poster
const showPoster = getShowImage(showSlug, false);
// Use ImageMetadata objects directly, not .src strings
const imageToUse = (hasEpisodeImage && image) ? image : showPoster;

// Determine if it should be a list layout
const isListLayout = layoutType === "list";
---

<div
  class:list={[
    "media-card",
    "media-card--hover",
    {
      "media-card--list": isListLayout,
    },
  ]}
>
  <a href={`/podcast/${slug}/`} class="media-card__link media-card__image media-card__image--video">
    <MediaImage
      src={imageToUse}
      alt={title}
      duration={duration.toString()}
      variant="podcast-duration"
      showDuration={!isListLayout}
      loading={loading}
    />
  </a>
  <div class="media-card__content">
    <a href={`/podcast/${slug}/`} class="media-card__title-link"><h3 class="media-card__title">{title}</h3></a>
    <a href={`/show/${showSlug}/`} class="media-card__eyebrow">{podcastTitle}</a>
    <div class="media-card__meta">
      <span><FormattedDate date={publishedAt} /></span> {isListLayout && 
      <span>•</span> <span>{formatDuration(duration)}</span>
    }
    </div>
    
  </div>
</div>

<style>
  .media-card__content a {
    text-decoration: none;
    border-bottom: none;
  }
</style>
