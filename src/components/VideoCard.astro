---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import FormattedDate from "../components/FormattedDate.astro";
import MediaImage from "./media/MediaImage.astro";
import { formatDuration } from "../utils/formatDuration";
import { IMAGE_WIDTHS, IMAGE_SIZES } from "../utils/imageSizes";

type Media = CollectionEntry<"media">;
type Props = Media["data"] & { 
  slug?: Media["slug"];
  loading?: "lazy" | "eager";
};

const {
  title,
  publishedAt,
  duration,
  poster,
  slug,
  layoutType = "grid",
  loading = "lazy",
} = Astro.props;

// Determine if it should be a list layout
const isListLayout = layoutType === "list";

const isImageMetadata = poster && typeof poster === 'object' && 'src' in poster;
---

<div
  class:list={[
    "media-card",
    "media-card--hover",
    {
      "media-card--list": isListLayout,
    },
  ]}
>
  <a href={`/video/${slug}/`} class="media-card__link media-card__image media-card__image--video">
    {isImageMetadata ? (
      <Image 
        src={poster as ImageMetadata} 
        alt={title} 
        widths={[...IMAGE_WIDTHS.large]}
        sizes={IMAGE_SIZES.large}
        loading={loading} 
      />
    ) : (
      <MediaImage src={poster} alt={title} ratio="video" loading={loading} />
    )}
  </a>
    <div class="media-card__content">
     <a href={`/video/${slug}/`} class="media-card__title-link"><h3 class="media-card__title">{title}</h3></a>
      <div class="media-card__meta">
        <span><FormattedDate date={publishedAt} /></span>
        <span>•</span>
        <span>{formatDuration(duration)}</span>
      </div>
    </div>
</div>

<style>
  a {
    text-decoration: none;
  }

  .duration {
    font-variant: small-caps;
    position: absolute;
    display: inline-block;
    color: white;
    background: rgba(0, 0, 0, 0.5);
    box-sizing: border-box;
    line-height: 1em;
    padding: 0.5em 0.5em 0.35em;
    border-radius: 0.4em;
    letter-spacing: 0.05em;

    font-size: 0.8rem;
    bottom: 0.5rem;
    right: 0.5rem;
  }

  @media screen and (max-width: 768px) {
    /* .media-card__image {
      border-radius: 2px;
    } */

    .duration {
      bottom: 0.4rem;
      right: 0.4rem;
      font-size: 0.7rem;
    }
  }
</style>
